# 邻里圈后端服务环境变量配置
# 使用方法：复制本文件为 .env 并根据实际环境修改各项值
# cp .env.example .env
#
# 标注说明：
#   [必填]      所有环境都必须配置
#   [生产必填]  生产环境（NODE_ENV=production）必须配置，否则启动时校验失败
#   [可选]      有合理默认值，可按需覆盖

# ==================== 应用配置 ====================
# 运行环境：development | test | production
# 生产环境会触发严格的配置校验，缺失关键配置将阻止启动
NODE_ENV=development
# 服务监听端口
PORT=3000
# 日志级别 [可选]：控制 pino 结构化日志输出级别
# 可选值：debug | info | warn | error
# 未配置时按环境兜底：开发环境 debug，其他环境 info
LOG_LEVEL=info

# ==================== PostgreSQL 数据库配置 ====================
# 数据库主机地址
# 本地开发：localhost；生产环境请通过 .env 配置实际地址，切勿提交真实 IP 到仓库
DB_HOST=localhost
# 数据库端口
DB_PORT=5432
# 数据库名称
DB_NAME=linli_circle
# 数据库用户名
DB_USER=postgres
# 数据库密码 [必填] 请根据实际环境配置，切勿提交真实密码到仓库
DB_PASSWORD=your-db-password-here

# ==================== Redis 配置 ====================
# Redis 主机地址
# 本地开发：localhost；生产环境请通过 .env 配置实际地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 密码 [生产必填] 生产环境必须设置，否则启动校验失败；开发环境可留空
REDIS_PASSWORD=your-redis-password-here
# Redis 数据库编号 [可选] 共享 Redis 实例时用于区分项目，社区默认 0
# 取值范围 0-15，未配置时默认使用 DB 0
REDIS_DB=0

# ==================== JWT 配置 ====================
# JWT 签名密钥 [必填] 生产环境务必使用高强度随机字符串，且不能使用默认值（如 your-secret-key）
# 可使用以下命令生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 切勿提交真实密钥到仓库，请通过 .env 配置实际值
JWT_SECRET=your-jwt-secret-here
# Access Token 过期时间
# 生产环境默认 2h（未配置时自动兜底为 2h），开发环境默认 7d
JWT_EXPIRES_IN=2h
# Refresh Token 过期时间
JWT_REFRESH_EXPIRES_IN=30d

# ==================== CORS 配置 ====================
# 允许的前端来源地址（多个用逗号分隔）[生产必填]
# 生产环境不能使用 localhost 或 127.0.0.1，否则启动校验失败
CORS_ORIGIN=http://localhost:5173

# ==================== 限流配置 ====================
# 限流时间窗口（毫秒）
RATE_LIMIT_WINDOW_MS=60000
# 时间窗口内最大请求数
RATE_LIMIT_MAX=100

# ==================== PII 加密配置 ====================
# PII（个人身份信息）加密密钥 [生产必填]：用于加密用户手机号等敏感字段（AES-256-GCM）
# 格式：32 字节 hex 字符串（64 个 hex 字符）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 注意：
#   1. 生产环境必须配置，否则启动校验失败
#   2. 密钥一旦配置后不可更改，否则已加密的数据将无法解密
#   3. 请妥善保管，不要提交到代码仓库
PII_ENCRYPT_KEY=

# ==================== AI 大模型配置 ====================
# AI 服务 API 密钥 [可选]：用于智能匹配、需求分类、安全风控等 AI 能力
# 兼容 OpenAI Chat Completions 协议的服务（OpenAI/通义千问/智谱等）
# 留空时 AI 相关功能将自动降级为规则匹配，不阻塞主流程
AI_API_KEY=
# AI 服务 API 地址 [可选]（不含 /chat/completions 后缀）
# OpenAI 默认：https://api.openai.com/v1
# 通义千问：https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱：https://open.bigmodel.cn/api/paas/v4
AI_API_BASE=https://api.openai.com/v1
# AI 模型名称 [可选]：兼容 OpenAI Chat Completions 协议的模型标识
# OpenAI：gpt-3.5-turbo / gpt-4o-mini
# 通义千问：qwen-turbo / qwen-plus
# 智谱：glm-4 / glm-4-flash
AI_MODEL=gpt-3.5-turbo
# AI Embedding 模型名称 [可选]：用于技能/帖子向量嵌入，留空时回退到 AI_MODEL
# 设计原因：部分服务商 Chat 与 Embedding 使用不同模型（如 OpenAI 的 text-embedding-3-small），
# 独立配置可让运维按成本与精度灵活选择 Embedding 模型而不影响 Chat 能力
# OpenAI：text-embedding-3-small / text-embedding-3-large
# 通义千问：text-embedding-v2 / text-embedding-v3
# 智谱：embedding-2 / embedding-3
AI_EMBEDDING_MODEL=

# ==================== 数据库备份配置 ====================
# 备份目录路径 [可选]：存放数据库备份文件的目录
# 默认值：项目根目录下的 backups/ 目录
# 备份文件命名格式：backup_YYYYMMDD_HHMMSS.sql.gz
# 备份文件保留 7 天，超过 7 天的备份会自动清理
BACKUP_DIR=

# ==================== 高德地图配置 ====================
# 高德地图 API Key [可选]：用于地理编码、逆地理编码、地图展示等功能
# 申请地址：https://lbs.amap.com/api/javascript-api/guide/abc/prepare
# 留空时地图相关功能将不可用，但不阻塞主流程
AMAP_KEY=

# ==================== 通知通道配置 ====================
# 站内信+WebSocket 默认启用，以下为外部通道（邮件/短信）开关 [可选]
# 未启用时通知仅写入数据库供站内信展示，不发送外部推送
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false

# SMTP 邮件配置（NOTIFICATION_EMAIL_ENABLED=true 时必填）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# 发件人地址 [可选]，未配置时回退到 SMTP_USER
SMTP_FROM=

# 短信服务商配置 [可选]
# SMS_PROVIDER 取值：aliyun / tencent / 空（降级为本地日志）
SMS_PROVIDER=
# 阿里云短信凭证（SMS_PROVIDER=aliyun 时使用）
SMS_ACCESS_KEY=
SMS_ACCESS_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=
SMS_ENDPOINT=dysmsapi.aliyuncs.com
# 腾讯云短信凭证（SMS_PROVIDER=tencent 时使用）
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_SDK_APP_ID=
SMS_TENCENT_SIGN_NAME=
SMS_TENCENT_TEMPLATE_ID=
SMS_TENCENT_REGION=ap-guangzhou

# ==================== OSS 云存储配置 ====================
# 未启用时使用本地磁盘存储 [可选]
# 启用后由 storage-adapter 自动切换到云存储，凭证齐全时生效
OSS_ENABLED=false
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# OSS 自定义域名（CDN 加速域名）[可选]
OSS_CUSTOM_DOMAIN=

# ==================== 图片白名单配置 ====================
# 允许的外链图片域名（逗号分隔）[可选]
# 本地上传的 /uploads/ 路径无需配置，自动放行
IMAGES_WHITELIST_DOMAINS=trae-api-cn.mchost.guru
